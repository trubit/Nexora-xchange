{
  "name": "my-nexora-app",
  "version": "0.0.0",
  "private": true,
  "description": "nexora website",
  "keywords": [
    "nexora"
  ],
  "homepage": "https://github.com/trubit/Nexora#readme",
  "bugs": {
    "url": "https://github.com/trubit/Nexora/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trubit/Nexora.git"
  },
  "license": "ISC",
  "author": "truson",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:dev": "nodemon server/index.js",
    "start": "concurrently -k -n \"CLIENT,SERVER\" -c \"cyan,green\" \"npm run dev\" \"npm run server:dev\"",
    "reset": "powershell -ExecutionPolicy Bypass -File kill-and-start.ps1",
    "docker:prod": "docker compose -f docker-compose.production.yml up --build",
    "test": "vitest --config vitest.workspace.js",
    "test:run": "vitest run --config vitest.workspace.js",
    "test:ui": "vitest --config vitest.workspace.js --ui",
    "test:coverage": "vitest run --config vitest.workspace.js --coverage",
    "test:client": "vitest run --config vitest.config.js",
    "test:client:watch": "vitest --config vitest.config.js",
    "test:client:coverage": "vitest run --config vitest.config.js --coverage",
    "test:server": "vitest run --config vitest.server.config.js",
    "test:server:watch": "vitest --config vitest.server.config.js",
    "test:server:coverage": "vitest run --config vitest.server.config.js --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:coverage && npm run test:e2e"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.10",
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bullmq": "^5.76.8",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^8.23.0",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.12.0",
    "react-ts-tradingview-widgets": "^1.2.8",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.1",
    "ws": "^8.19.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "vite": "^7.2.4",
    "vitest": "^4.1.9"
  }
}
